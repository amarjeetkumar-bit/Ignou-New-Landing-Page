# LeadSquared API credentials — set these in the Vercel dashboard
# (Project → Settings → Environment Variables). Do NOT commit real keys.
LSQ_ACCESS_KEY=your_leadsquared_access_key
LSQ_SECRET_KEY=your_leadsquared_secret_key

# Optional: LeadSquared regional host (default: api-in21.leadsquared.com)
LSQ_HOST=api-in21.leadsquared.com
